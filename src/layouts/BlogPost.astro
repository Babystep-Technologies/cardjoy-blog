---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { coverHue } from '../utils/coverColor';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroLink, heroVideo } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.hero-image .hero-video-wrap {
					position: relative;
					width: 100%;
					max-width: 1020px;
					margin: 0 auto;
					cursor: pointer;
				}
				.hero-image .hero-video {
					display: block;
					width: 100%;
					border-radius: 12px;
					box-shadow: var(--box-shadow);
					background: #000;
				}
				.hero-image .hero-play {
					position: absolute;
					top: 50%;
					left: 50%;
					transform: translate(-50%, -50%);
					width: 88px;
					height: 88px;
					padding: 0;
					border: none;
					background: none;
					cursor: pointer;
					color: #fff;
					transition: transform 0.15s ease, opacity 0.2s ease;
				}
				.hero-image .hero-play svg {
					width: 100%;
					height: 100%;
					display: block;
					filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.35));
				}
				.hero-image .hero-play svg circle {
					fill: rgba(0, 0, 0, 0.55);
				}
				.hero-image .hero-play svg path {
					fill: #fff;
				}
				.hero-image .hero-video-wrap:hover .hero-play {
					transform: translate(-50%, -50%) scale(1.08);
				}
				.hero-image .hero-video-wrap.playing .hero-play {
					opacity: 0;
					pointer-events: none;
				}
				.hero-image .hero-link {
				display: block;
				cursor: pointer;
			}
			.hero-image .hero-link img {
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.hero-image .hero-link:hover img {
				transform: scale(1.01);
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
			}
			.hero-image .no-image-cover {
				width: 100%;
				max-width: 1020px;
				margin: 0 auto;
				aspect-ratio: 2 / 1;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2rem;
				box-sizing: border-box;
				text-align: center;
				container-type: inline-size;
				background: linear-gradient(
					135deg,
					hsl(var(--cover-hue) 70% 55%),
					hsl(calc(var(--cover-hue) + 40) 65% 42%)
				);
			}
			.hero-image .cover-title {
				color: #fff;
				font-weight: 700;
				line-height: 1.15;
				font-size: clamp(1.2rem, 6cqi, 3rem);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroVideo ? (
						<div class="hero-video-wrap">
							<video
								class="hero-video"
								src={heroVideo}
								poster={heroImage}
								playsinline
								preload="none"
								aria-label={`Watch: ${title}`}
							></video>
							<button class="hero-play" type="button" aria-label={`Play: ${title}`}>
								<svg viewBox="0 0 68 68" aria-hidden="true" focusable="false">
									<circle cx="34" cy="34" r="34" />
									<path d="M27 22l22 12-22 12z" />
								</svg>
							</button>
						</div>
					) : heroImage ? (
						heroLink ? (
							<a class="hero-link" href={heroLink} target="_blank" rel="noopener" aria-label={`Watch: ${title}`}>
								<img width={1020} height={510} src={heroImage} alt="" />
							</a>
						) : (
							<img width={1020} height={510} src={heroImage} alt="" />
						)
					) : (
						<div class="no-image-cover" style={`--cover-hue:${coverHue(title)}`}>
							<span class="cover-title">{title}</span>
						</div>
					)}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			// A click anywhere on the hero poster (or the branded play icon) starts
			// playback, hides the overlay, and hands off to native controls. After
			// that first click the handler detaches so native controls behave normally.
			document.querySelectorAll<HTMLDivElement>('.hero-video-wrap').forEach((wrap) => {
				const video = wrap.querySelector<HTMLVideoElement>('video.hero-video');
				if (!video) return;
				const start = () => {
					wrap.classList.add('playing');
					video.controls = true;
					video.play();
					wrap.removeEventListener('click', start);
				};
				wrap.addEventListener('click', start);
			});
		</script>
	</body>
</html>
