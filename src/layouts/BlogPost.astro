---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { coverHue } from '../utils/coverColor';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroLink, heroVideo } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.hero-image .hero-video {
					display: block;
					width: 100%;
					max-width: 1020px;
					margin: 0 auto;
					border-radius: 12px;
					box-shadow: var(--box-shadow);
					cursor: pointer;
					background: #000;
				}
				.hero-image .hero-link {
				display: block;
				cursor: pointer;
			}
			.hero-image .hero-link img {
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.hero-image .hero-link:hover img {
				transform: scale(1.01);
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
			}
			.hero-image .no-image-cover {
				width: 100%;
				max-width: 1020px;
				margin: 0 auto;
				aspect-ratio: 2 / 1;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2rem;
				box-sizing: border-box;
				text-align: center;
				container-type: inline-size;
				background: linear-gradient(
					135deg,
					hsl(var(--cover-hue) 70% 55%),
					hsl(calc(var(--cover-hue) + 40) 65% 42%)
				);
			}
			.hero-image .cover-title {
				color: #fff;
				font-weight: 700;
				line-height: 1.15;
				font-size: clamp(1.2rem, 6cqi, 3rem);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroVideo ? (
						<video
							class="hero-video"
							src={heroVideo}
							poster={heroImage}
							controls
							playsinline
							preload="none"
							aria-label={`Watch: ${title}`}
						></video>
					) : heroImage ? (
						heroLink ? (
							<a class="hero-link" href={heroLink} target="_blank" rel="noopener" aria-label={`Watch: ${title}`}>
								<img width={1020} height={510} src={heroImage} alt="" />
							</a>
						) : (
							<img width={1020} height={510} src={heroImage} alt="" />
						)
					) : (
						<div class="no-image-cover" style={`--cover-hue:${coverHue(title)}`}>
							<span class="cover-title">{title}</span>
						</div>
					)}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			// Let a click anywhere on the hero poster start playback (not just the
			// default play button), so the hero image itself plays the demo inline.
			document.querySelectorAll<HTMLVideoElement>('video.hero-video').forEach((video) => {
				video.addEventListener('click', (event) => {
					if (video.paused) {
						video.play();
						event.preventDefault();
					}
				});
			});
		</script>
	</body>
</html>
